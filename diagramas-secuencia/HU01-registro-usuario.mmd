sequenceDiagram
    title HU01 - Registro de usuario
    actor U as Usuario nuevo
    participant LH as login.html
    participant LJ as login.js
    participant AC as AuthController
    participant AS as AuthService
    participant UR as UsuarioRepository
    participant DB as Base de datos

    U->>LH: Completa formulario (nombre, email, password)
    U->>LH: Click "Registrar"
    LH->>LJ: registrar()
    LJ->>LJ: Valida campos obligatorios
    LJ->>LJ: Valida formato de password (regex)

    alt Validación falla
        LJ-->>U: Muestra error en pantalla
    else Validación pasa
        LJ->>AC: POST /usuarios {nombre, email, password}
        AC->>AS: registrar(usuario)
        AS->>AS: validarPassword(password)

        alt Password inválido
            AS-->>AC: throw RuntimeException
            AC-->>LJ: 400 {error: "..."}
            LJ-->>U: Muestra mensaje de error
        else Password válido
            AS->>AS: usuario.setNivel("basico")
            AS->>AS: usuario.setQuizzesCompletados(0)
            AS->>UR: save(usuario)
            UR->>DB: INSERT INTO usuarios

            alt Email duplicado (constraint unique)
                DB-->>UR: SQLException
                UR-->>AS: DataIntegrityViolation
                AS-->>AC: throw
                AC-->>LJ: 400 {error}
                LJ-->>U: "Usuario ya existe"
            else OK
                DB-->>UR: Usuario guardado
                UR-->>AS: Usuario nuevo
                AS-->>AC: Usuario
                AC-->>LJ: 200 OK con Usuario
                LJ-->>U: alert("Cuenta creada correctamente")
                LJ->>LH: mostrarLogin()
            end
        end
    end
