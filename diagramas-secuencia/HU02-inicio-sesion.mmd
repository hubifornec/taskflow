sequenceDiagram
    title HU02 - Inicio de sesión
    actor U as Usuario registrado
    participant LH as login.html
    participant LJ as login.js
    participant SS as sessionStorage
    participant AC as AuthController
    participant AS as AuthService
    participant UR as UsuarioRepository
    participant DB as Base de datos

    U->>LH: Ingresa email y password
    U->>LH: Click "Iniciar sesión"
    LH->>LJ: login()
    LJ->>AC: POST /login {email, password}
    AC->>AS: login(email, password)
    AS->>UR: findByEmailAndPassword(email, password)
    UR->>DB: SELECT * FROM usuarios WHERE email=? AND password=?

    alt Credenciales inválidas
        DB-->>UR: vacío
        UR-->>AS: Optional.empty()
        AS-->>AC: null
        AC-->>LJ: 401 "Credenciales incorrectas"
        LJ-->>U: Muestra mensaje de error
    else Credenciales válidas
        DB-->>UR: Usuario encontrado
        UR-->>AS: Optional con Usuario
        AS-->>AC: Usuario
        AC-->>LJ: 200 OK con Usuario
        LJ->>SS: setItem("usuario", JSON.stringify(usuario))
        LJ->>LH: window.location.href = "/index.html"
        LH-->>U: Redirige al dashboard
    end
