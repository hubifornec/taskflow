sequenceDiagram
    title HU03 - Visualización de tablero Scrum
    actor U as Usuario
    participant IH as index.html
    participant SJ as script.js
    participant SS as sessionStorage
    participant TC as TareaController
    participant TS as TareaService
    participant TR as TareaRepository
    participant DB as Base de datos

    U->>IH: Carga la página
    IH->>SJ: init() autoejecutado
    SJ->>SS: getItem("usuario")

    alt Sin usuario en sesión
        SS-->>SJ: null
        SJ->>IH: redirect a /login.html
    else Usuario válido
        SS-->>SJ: Usuario
        SJ->>SJ: cargarTareas()
        SJ->>TC: GET /tareas?usuarioId={id}
        TC->>TS: obtenerPorUsuario(usuarioId)
        TS->>TR: findByUsuarioId(usuarioId)
        TR->>DB: SELECT * FROM tareas WHERE usuario_id=?
        DB-->>TR: Lista de tareas
        TR-->>TS: List Tarea
        TS-->>TC: List Tarea
        TC-->>SJ: 200 OK con tareas

        loop Para cada tarea
            SJ->>SJ: crearTarjetaTarea(tarea)
            SJ->>SJ: append a columna según tarea.estado
        end

        SJ-->>IH: Renderiza columnas (pendiente, en_proceso, completada)
        IH-->>U: Muestra tablero con tarjetas
    end
