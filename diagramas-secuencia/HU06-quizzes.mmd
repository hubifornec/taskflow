sequenceDiagram
    title HU06 - Evaluación mediante quizzes
    actor U as Usuario
    participant IH as index.html
    participant SJ as script.js
    participant SS as sessionStorage
    participant QC as QuizController
    participant QS as QuizService
    participant PR as PreguntaRepository
    participant AC as AuthController
    participant AS as AuthService
    participant UR as UsuarioRepository
    participant DB as Base de datos

    U->>IH: Click "Hacer quiz" en módulo
    IH->>SJ: iniciarQuiz(cuestionarioId, titulo)
    SJ->>QC: GET /api/quiz/{cuestionarioId}
    QC->>QS: obtenerPreguntasPorCuestionario(id)
    QS->>PR: findByCuestionarioId(cuestionarioId)
    PR->>DB: SELECT * FROM preguntas WHERE cuestionario_id=?
    DB-->>PR: Lista de preguntas
    PR-->>QS: List Pregunta
    QS-->>QC: List Pregunta
    QC-->>SJ: 200 OK con preguntas
    SJ->>SJ: preguntasActivas = preguntas, indicePregunta = 0
    SJ->>SJ: mostrarPregunta()
    SJ-->>U: Muestra pregunta 1 con opciones

    loop Por cada pregunta
        U->>IH: Selecciona una opción
        IH->>SJ: seleccionarOpcion(boton)
        SJ-->>IH: Habilita botón "Confirmar"

        U->>IH: Click "Confirmar respuesta"
        IH->>SJ: confirmarRespuesta(preguntaId)
        SJ->>QC: POST /api/quiz/answer {preguntaId, respuesta}
        QC->>QS: validarRespuesta(preguntaId, respuesta)
        QS->>PR: findById(preguntaId)
        PR->>DB: SELECT * FROM preguntas WHERE id=?
        DB-->>PR: Pregunta
        PR-->>QS: Pregunta
        QS->>QS: Compara respuestaCorrecta con respuesta
        QS-->>QC: Map {correcto, respuestaCorrecta, puntaje}
        QC-->>SJ: 200 OK con feedback

        alt Respuesta correcta
            SJ-->>U: ✅ "+puntaje puntos" (verde)
            SJ->>SJ: puntajeAcumulado += puntaje
        else Respuesta incorrecta
            SJ-->>U: ❌ "Correcta era: ..." (rojo)
        end

        U->>IH: Click "Siguiente"
        IH->>SJ: siguientePregunta()
    end

    SJ->>SJ: mostrarResultadoFinal()
    SJ->>SJ: Calcula porcentaje (puntajeAcumulado / total)
    SJ-->>U: Muestra resultado (Aprobado/No aprobado)

    alt Quiz aprobado (>= 60%)
        SJ->>SS: getItem("usuario")
        SJ->>AC: POST /usuarios/{id}/completar-quiz
        AC->>AS: completarQuiz(id)
        AS->>UR: findById(id)
        UR->>DB: SELECT * FROM usuarios WHERE id=?
        DB-->>UR: Usuario
        UR-->>AS: Usuario
        AS->>AS: setQuizzesCompletados(actual + 1)

        alt 4+ quizzes Y nivel="basico"
            AS->>AS: setNivel("avanzado")
        end

        AS->>UR: save(usuario)
        UR->>DB: UPDATE usuarios SET quizzes_completados=?, nivel=?
        DB-->>UR: OK
        UR-->>AS: Usuario actualizado
        AS-->>AC: Usuario
        AC-->>SJ: 200 OK
        SJ->>SS: setItem("usuario", usuarioActualizado)

        alt Subió a avanzado
            SJ-->>U: 🎉 "Has desbloqueado Nivel Avanzado"
        end
    end
