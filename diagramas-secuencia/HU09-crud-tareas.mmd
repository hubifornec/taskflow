sequenceDiagram
    title HU09 - Gestión de tareas (CRUD)
    actor U as Usuario
    participant IH as index.html
    participant SJ as script.js
    participant SS as sessionStorage
    participant TC as TareaController
    participant TS as TareaService
    participant TR as TareaRepository
    participant DB as Base de datos

    rect rgb(220, 240, 220)
    Note over U,DB: CREATE — Crear nueva tarea
    U->>IH: Click "Crear tarea"
    IH-->>U: Muestra formulario
    U->>IH: Completa título, descripción, fecha, prioridad
    U->>IH: Click "Guardar"
    IH->>SJ: guardarTarea()
    SJ->>SS: getItem("usuario")

    alt Título vacío
        SJ-->>U: alert "El título es obligatorio"
    else Título válido
        SJ->>TC: POST /tareas {titulo, descripcion, columnaId:1, usuarioId, prioridad, fechaVencimiento}
        TC->>TS: crear(tarea)
        TS->>TR: save(tarea)
        TR->>DB: INSERT INTO tareas (...)
        DB-->>TR: Tarea con id generado
        TR-->>TS: Tarea
        TS-->>TC: Tarea
        TC-->>SJ: 200 OK con Tarea
        SJ->>SJ: cerrarFormulario()
        SJ->>SJ: cargarTareas()
        SJ-->>U: Tarjeta nueva visible en columna "Pendientes"
    end
    end

    rect rgb(220, 230, 240)
    Note over U,DB: READ — Visualizar tareas (ver HU03)
    U->>SJ: Carga inicial / cambio de sección
    SJ->>TC: GET /tareas?usuarioId
    TC->>TS: obtenerPorUsuario
    TS->>TR: findByUsuarioId
    TR->>DB: SELECT
    DB-->>SJ: lista de tareas
    SJ-->>U: Renderiza tablero
    end

    rect rgb(240, 235, 215)
    Note over U,DB: UPDATE — Editar tarea (PUT)
    U->>IH: Click ✏️ en una tarjeta
    IH->>SJ: abrirEdicion(id, titulo, descripcion, prioridad, fecha)
    SJ-->>U: Muestra modal con campos pre-llenados
    U->>IH: Modifica datos y click "Guardar"
    IH->>SJ: guardarEdicion()

    alt Título vacío
        SJ-->>U: alert "El título es obligatorio"
    else Datos válidos
        SJ->>TC: PUT /tareas/{id} {titulo, descripcion, prioridad, fechaVencimiento}
        TC->>TS: editar(id, tarea)
        TS->>TR: findById(id)
        TR->>DB: SELECT WHERE id=?

        alt Tarea no existe
            DB-->>TR: vacío
            TS-->>TC: throw RuntimeException
            TC-->>SJ: 500 {error}
        else Tarea encontrada
            DB-->>TR: Tarea
            TR-->>TS: Tarea
            TS->>TS: setTitulo, setDescripcion, setPrioridad, setFechaVencimiento
            TS->>TR: save(tarea)
            TR->>DB: UPDATE tareas SET ...
            DB-->>TR: OK
            TR-->>TS: Tarea actualizada
            TS-->>TC: Tarea
            TC-->>SJ: 200 OK
        end

        SJ->>SJ: Cierra modal
        SJ->>SJ: cargarTareas()
        SJ-->>U: Tarjeta refleja los cambios
    end
    end

    rect rgb(255, 240, 215)
    Note over U,DB: UPDATE estado — Drag and drop (ver HU04)
    U->>SJ: Drop en otra columna
    SJ->>TC: PATCH /tareas/{id}/status
    TC->>TS: actualizarEstado
    TS->>TR: findById, setEstado, save
    TR->>DB: UPDATE
    DB-->>SJ: OK
    SJ-->>U: Tablero actualizado
    end

    rect rgb(245, 220, 220)
    Note over U,DB: DELETE — Eliminar tarea
    U->>IH: Click 🗑️ en una tarjeta
    IH->>SJ: eliminarTarea(id)
    SJ-->>U: confirm "¿Seguro que deseas eliminar?"

    alt Usuario cancela
        U-->>SJ: Cancela
        SJ->>SJ: return
    else Usuario confirma
        U-->>SJ: Acepta
        SJ->>TC: DELETE /tareas/{id}
        TC->>TS: eliminar(id)
        TS->>TR: deleteById(id)
        TR->>DB: DELETE FROM tareas WHERE id=?
        DB-->>TR: OK
        TR-->>TS: void
        TS-->>TC: void
        TC-->>SJ: 200 OK {mensaje:"Tarea eliminada"}
        SJ->>SJ: cargarTareas()
        SJ-->>U: Tarjeta desaparece del tablero
    end
    end
