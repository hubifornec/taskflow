sequenceDiagram
    title HU10 - Reportes y estadísticas
    actor U as Usuario
    participant IH as index.html
    participant SJ as script.js
    participant CV as Canvas (graficaEstados)
    participant TC as TareaController
    participant TS as TareaService
    participant TR as TareaRepository
    participant DB as Base de datos

    U->>IH: Click en sección "Reportes"
    IH->>SJ: mostrarSeccion("reportes")
    SJ->>SJ: cargarReportes()
    SJ->>TC: GET /api/user/stats?usuarioId={id}
    TC->>TS: obtenerStats(usuarioId)

    par Consultas en paralelo
        TS->>TR: countByUsuarioId(usuarioId)
        TR->>DB: SELECT COUNT(*) FROM tareas
        DB-->>TR: total
    and
        TS->>TR: findByUsuarioIdAndEstado("pendiente")
        TR->>DB: SELECT WHERE estado="pendiente"
        DB-->>TR: lista pendientes
    and
        TS->>TR: findByUsuarioIdAndEstado("en_proceso")
        TR->>DB: SELECT WHERE estado="en_proceso"
        DB-->>TR: lista en proceso
    and
        TS->>TR: findByUsuarioIdAndEstado("completada")
        TR->>DB: SELECT WHERE estado="completada"
        DB-->>TR: lista completadas
    end

    TS-->>TC: Map {total, pendientes, enProceso, completadas}
    TC-->>SJ: 200 OK con stats

    alt Sin tareas registradas
        SJ-->>IH: Oculta canvas
        SJ-->>U: "No hay datos registrados aún"
    else Hay tareas
        SJ-->>IH: Muestra resumen textual
        SJ->>SJ: dibujarGrafica(stats)
        SJ->>CV: clearRect (limpia canvas)
        SJ->>CV: stroke ejes X e Y

        loop Por cada estado (pendientes, en proceso, completadas)
            SJ->>CV: fillRect (dibuja barra coloreada)
            SJ->>CV: fillText (etiqueta + valor)
        end

        CV-->>U: Gráfico de barras con distribución de tareas
        IH-->>U: Resumen + gráfico interactivo
    end
